# Global configuration — shared by ALL services in every environment.
# Safe to commit. No secrets here.

# Infrastructure addresses (resolved via CoreDNS within namespace)
GLOBAL_POSTGRES_HOST=postgres
GLOBAL_POSTGRES_PORT=5432
GLOBAL_REDIS_HOST=redis
GLOBAL_REDIS_PORT=6379
GLOBAL_VAULT_ADDR=http://vault:8200

# Application settings
GLOBAL_LOG_LEVEL=INFO
GLOBAL_APP_ENV=dev
GLOBAL_JWT_ALGORITHM=HS256

# Feature flags (default: off)
GLOBAL_FEATURE_NEW_CHECKOUT=false
GLOBAL_FEATURE_DARK_MODE=false
