# Global secrets example — copy to global.env and fill in dev-safe values.
# global.env is gitignored. NEVER commit real secrets.

POSTGRES_PASSWORD=change-me-dev-password
REDIS_PASSWORD=change-me-dev-password
JWT_SECRET=change-me-dev-jwt-secret-at-least-32-chars

# External API keys (use test/sandbox keys for dev)
# STRIPE_API_KEY=sk_test_...
# SENDGRID_API_KEY=SG.test...
# GOOGLE_OAUTH_CLIENT_SECRET=...
